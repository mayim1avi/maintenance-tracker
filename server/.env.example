PORT=4000
JWT_SECRET=change-me-to-a-long-random-string
# Where the SQLite file + uploaded photos are stored. Leave unset for local dev
# (defaults to the server folder). In production point this at a persistent disk,
# e.g. DATA_DIR=/var/data on Render.
# DATA_DIR=/var/data
# Seeded on first run (only if no admin exists yet)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_NAME=מנהל מערכת
# Comma-separated origins allowed for CORS in dev (Vite default below)
CLIENT_ORIGIN=http://localhost:5173
